# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local form-submission data (filesystem store; never commit submissions)
/data/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep the documented example; ignore real secrets)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python tooling cache (pre-existing, unrelated to the web app)
.pytest_cache/

# Local plan rendering (not tracked; source of truth is .claude/plans/website-plan.md)
website-plan.html
.gstack/
