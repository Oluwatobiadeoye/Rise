# RISE website — environment variables
#
# None of these are needed yet. Copy this file to `.env.local` (git-ignored)
# and fill in real values when each feature is added.
# Never commit real secrets — only this example file is tracked.

# --- Supabase (forms & applications) ---
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=        # server-only — never expose to the client

# --- Sanity (blog & gallery) ---
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_READ_TOKEN=

# --- Resend (submission notifications) ---
# RESEND_API_KEY=
# RISE_NOTIFY_EMAIL=

# --- Cloudflare Turnstile (spam protection) ---
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
